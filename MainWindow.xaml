<Window x:Class="guinea_football_club_erp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Guinea Football Club — ERP"
        Height="750" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Width" Value="204"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{DynamicResource MaterialDesign.Brush.Primary}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,8">
                    <TextBlock Text="⚽" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="GFC ERP" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="Guinea Football Club" FontSize="11"
                               Foreground="#CCFFFFFF" HorizontalAlignment="Center"/>
                    <Separator Margin="0,14,0,0" Background="#44FFFFFF"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0 — 2026"
                           Foreground="#88FFFFFF" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <!-- Utilisateur connecté + déconnexion -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10,0,10,6">
                    <Separator Background="#44FFFFFF" Margin="0,6,0,8"/>
                    <TextBlock x:Name="TbUserName" Text="—"
                               Foreground="White" FontWeight="Medium"
                               HorizontalAlignment="Center" FontSize="13"/>
                    <TextBlock x:Name="TbUserRole" Text="—"
                               Foreground="#CCFFFFFF"
                               HorizontalAlignment="Center" FontSize="11" Margin="0,2,0,6"/>
                    <Button Content="🚨  Déconnexion" Click="BtnLogout_Click"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" HorizontalAlignment="Stretch"
                            Height="32" FontSize="12"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,4,8,8">
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Dashboard"  Content="📊  Tableau de bord"  Click="Nav_Click"/>
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Clubs"      Content="🏙  Clubs"             Click="Nav_Click"/>
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Joueurs"    Content="👤  Joueurs"           Click="Nav_Click"/>
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Matches"    Content="⚽  Matchs"            Click="Nav_Click"/>
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Actualites" Content="📰  Actualités"        Click="Nav_Click"/>
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Boutique"   Content="🛍  Boutique"          Click="Nav_Click"/>
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Billets"    Content="🏟  Billets"           Click="Nav_Click"/>
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Classement" Content="🏆  Classement"        Click="Nav_Click"/>
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Palmares"   Content="🥇  Palmarès"          Click="Nav_Click"/>
                        <Button Style="{StaticResource NavButtonStyle}" Tag="Photos"     Content="📷  Photos"            Click="Nav_Click"/>
                        <Separator Background="#44FFFFFF" Margin="4,8,4,4"/>
                        <Button x:Name="BtnNavUsers" Style="{StaticResource NavButtonStyle}" Tag="Users"
                                Content="👥  Utilisateurs"       Click="Nav_Click" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- CONTENU PRINCIPAL -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
