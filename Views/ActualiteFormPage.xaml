<Page x:Class="guinea_football_club_erp.Views.ActualiteFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Actualité — Formulaire">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="700">
            <Button Content="← Retour" HorizontalAlignment="Left" Click="BtnBack_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,16"/>
            <TextBlock x:Name="TbTitle" FontSize="24" FontWeight="Bold" Margin="0,0,0,24"/>

            <ComboBox x:Name="CbClub"     materialDesign:HintAssist.Hint="Club" Margin="0,0,0,12"
                      DisplayMemberPath="Nom" SelectedValuePath="Id"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
            <TextBox x:Name="TbTitre"     materialDesign:HintAssist.Hint="Titre" Margin="0,0,0,12" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <TextBox x:Name="TbCategorie" materialDesign:HintAssist.Hint="Catégorie article" Margin="0,0,0,12" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <TextBox x:Name="TbImage"     materialDesign:HintAssist.Hint="URL image (optionnel)" Margin="0,0,0,12" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <TextBox x:Name="TbContenu"   materialDesign:HintAssist.Hint="Contenu" Margin="0,0,0,12"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="150"/>
            <CheckBox x:Name="CkPublie" Content="Publié" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="BtnDelete" Content="Supprimer" Margin="0,0,12,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="Red" Click="BtnDelete_Click" Visibility="Collapsed"/>
                <Button Content="Enregistrer" Click="BtnSave_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
