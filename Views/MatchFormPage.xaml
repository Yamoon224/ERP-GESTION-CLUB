<Page x:Class="guinea_football_club_erp.Views.MatchFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Match — Formulaire">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="600">
            <Button Content="← Retour" HorizontalAlignment="Left" Click="BtnBack_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,16"/>
            <TextBlock x:Name="TbTitle" FontSize="24" FontWeight="Bold" Margin="0,0,0,24"/>

            <ComboBox x:Name="CbClub"       materialDesign:HintAssist.Hint="Club" Margin="0,0,0,12"
                      DisplayMemberPath="Nom" SelectedValuePath="Id"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
            <TextBox x:Name="TbAdversaire"  materialDesign:HintAssist.Hint="Adversaire" Margin="0,0,0,12" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <TextBox x:Name="TbDate"        materialDesign:HintAssist.Hint="Date du match" Margin="0,0,0,12" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <TextBox x:Name="TbCompetition" materialDesign:HintAssist.Hint="Compétition" Margin="0,0,0,12" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <TextBox x:Name="TbStade"       materialDesign:HintAssist.Hint="Stade" Margin="0,0,0,12" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <ComboBox x:Name="CbLieu"       materialDesign:HintAssist.Hint="Lieu" Margin="0,0,0,12"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
            <ComboBox x:Name="CbCategorie"  materialDesign:HintAssist.Hint="Catégorie" Margin="0,0,0,12"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
            <ComboBox x:Name="CbStatut"     materialDesign:HintAssist.Hint="Statut" Margin="0,0,0,12"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbScoreClub"      Grid.Column="0" Margin="0,0,6,0" materialDesign:HintAssist.Hint="Score club"      Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                <TextBox x:Name="TbScoreAdversaire" Grid.Column="1" Margin="6,0,0,0" materialDesign:HintAssist.Hint="Score adversaire" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="BtnDelete" Content="Supprimer" Margin="0,0,12,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="Red" Click="BtnDelete_Click" Visibility="Collapsed"/>
                <Button Content="Enregistrer" Click="BtnSave_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
