<Page x:Class="guinea_football_club_erp.Views.ClassementFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Classement — Formulaire">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="600">
            <Button Content="← Retour" HorizontalAlignment="Left" Click="BtnBack_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,16"/>
            <TextBlock x:Name="TbTitle" FontSize="24" FontWeight="Bold" Margin="0,0,0,24"/>

            <ComboBox x:Name="CbClub"       materialDesign:HintAssist.Hint="Club" Margin="0,0,0,12"
                      DisplayMemberPath="Nom" SelectedValuePath="Id"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
            <TextBox x:Name="TbCompetition" materialDesign:HintAssist.Hint="Compétition" Margin="0,0,0,12" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <TextBox x:Name="TbSaison"      materialDesign:HintAssist.Hint="Saison (ex: 2025)" Margin="0,0,0,12" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <ComboBox x:Name="CbCategorie"  materialDesign:HintAssist.Hint="Catégorie" Margin="0,0,0,12"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbPos" Grid.Column="0" Margin="0,0,4,0" materialDesign:HintAssist.Hint="Position" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                <TextBox x:Name="TbPts" Grid.Column="1" Margin="4,0,4,0" materialDesign:HintAssist.Hint="Points"   Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                <TextBox x:Name="TbJ"   Grid.Column="2" Margin="4,0,0,0" materialDesign:HintAssist.Hint="Joués"    Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbV"  Grid.Column="0" Margin="0,0,4,0" materialDesign:HintAssist.Hint="V"  Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                <TextBox x:Name="TbN"  Grid.Column="1" Margin="4,0,4,0" materialDesign:HintAssist.Hint="N"  Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                <TextBox x:Name="TbD"  Grid.Column="2" Margin="4,0,4,0" materialDesign:HintAssist.Hint="D"  Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                <TextBox x:Name="TbBP" Grid.Column="3" Margin="4,0,4,0" materialDesign:HintAssist.Hint="BP" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                <TextBox x:Name="TbBC" Grid.Column="4" Margin="4,0,0,0" materialDesign:HintAssist.Hint="BC" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="BtnDelete" Content="Supprimer" Margin="0,0,12,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="Red" Click="BtnDelete_Click" Visibility="Collapsed"/>
                <Button Content="Enregistrer" Click="BtnSave_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
