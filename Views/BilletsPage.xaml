<Page x:Class="guinea_football_club_erp.Views.BilletsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="White"
      Title="Billets">
    <DockPanel Margin="24">

        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Gestion des Billets" FontSize="24" FontWeight="Bold"
                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Content="+ Nouveau billet" Margin="16,0,0,0" Click="BtnAdd_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <TextBox x:Name="TbSearch" HorizontalAlignment="Right" Width="240"
                     VerticalAlignment="Center" Height="36"
                     materialDesign:HintAssist.Hint="🔍 Rechercher..."
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     TextChanged="TbSearch_TextChanged"/>
        </DockPanel>

        <!-- Pagination -->
        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0" Padding="8,6"
                Background="#F5F5F5" CornerRadius="6"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <Button x:Name="BtnPrev" Content="◀ Précédent" Click="BtnPrev_Click"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        DockPanel.Dock="Left" Height="32" Padding="12,0"/>
                <Button x:Name="BtnNext" Content="Suivant ▶" Click="BtnNext_Click"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        DockPanel.Dock="Right" Height="32" Padding="12,0"/>
                <TextBlock x:Name="TbPageInfo" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontSize="13" Foreground="#616161"/>
            </DockPanel>
        </Border>

        <!-- DataGrid -->
        <Border CornerRadius="8" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="#BDBDBD" BlurRadius="16" ShadowDepth="2"
                                  Opacity="0.35" Direction="270"/>
            </Border.Effect>
            <Border CornerRadius="8" ClipToBounds="True"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <DataGrid x:Name="DgBillets" AutoGenerateColumns="False"
                          CanUserResizeRows="False" Background="White"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="8,6,8,6"
                          SelectionChanged="Dg_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Club"       Binding="{Binding Club.Acronyme}"      Width="80"/>
                        <DataGridTextColumn Header="Match"      Binding="{Binding Match.Adversaire}"   Width="*"/>
                        <DataGridTextColumn Header="Type"       Binding="{Binding TypePlace}"          Width="100"/>
                        <DataGridTextColumn Header="Prix"       Binding="{Binding Prix}"               Width="130"/>
                        <DataGridTextColumn Header="Disponibles" Binding="{Binding NombreDisponible}"  Width="100"/>
                        <DataGridTextColumn Header="Total"      Binding="{Binding NombreTotal}"        Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>

    </DockPanel>
</Page>
